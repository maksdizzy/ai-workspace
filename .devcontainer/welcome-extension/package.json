{
  "name": "ai-workspace-welcome",
  "displayName": "AI Workspace — Welcome",
  "description": "Welcome panel and setup commands for AI Workspace",
  "version": "0.1.0",
  "publisher": "maksdizzy",
  "engines": {
    "vscode": "^1.85.0"
  },
  "activationEvents": ["onStartupFinished"],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "ai-workspace.notebooklmLogin",
        "title": "AI Workspace: Connect NotebookLM"
      },
      {
        "command": "ai-workspace.openIntegrations",
        "title": "AI Workspace: Open Integrations"
      },
      {
        "command": "ai-workspace.openSkills",
        "title": "AI Workspace: Open Skills"
      }
    ]
  }
}
